# Core service bind/runtime
CORE_RPC_ADDR=:19090
LLM_RPC_ADDR=127.0.0.1:51000
# If local env cannot bind TCP gRPC ports, switch to:
# LLM_RPC_ADDR=unix:///tmp/llm-python-rpc.sock
LLM_RPC_DIAL_TIMEOUT_SECONDS=8
DATA_DIR=./data

# Auth persistence
MYSQL_DSN=app:app123456@tcp(127.0.0.1:3306)/llm_doc_qa?parseTime=true&charset=utf8mb4&loc=Local

# Object storage
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=qa-documents
MINIO_USE_SSL=false

# Vector retrieval pipeline (chunk embedding + Qdrant)
VECTOR_SEARCH_ENABLED=false
QDRANT_ENDPOINT=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=qa_chunks
QDRANT_TIMEOUT_SECONDS=10

# Shared LLM provider settings (consumed by llm-python-rpc)
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_CHAT_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
SILICONFLOW_TEMPERATURE=0.2
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
SILICONFLOW_TIMEOUT_SECONDS=30
LLM_PROVIDER=siliconflow
LLM_AGENT_MAX_CONTEXT_CHUNKS=6

# Optional provider-specific chat model mapping (JSON)
# SILICONFLOW_PROVIDER_CHAT_MODELS_JSON={"openai":"Pro/MiniMaxAI/MiniMax-M2.5","claude":"Pro/MiniMaxAI/MiniMax-M2.5"}
