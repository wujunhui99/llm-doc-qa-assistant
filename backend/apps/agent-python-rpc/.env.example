AGENT_RPC_HOST=0.0.0.0
AGENT_RPC_PORT=51000
# Backward compatible env names:
# LLM_RPC_HOST=0.0.0.0
# LLM_RPC_PORT=51000
# Optional explicit listen address (supports unix socket):
# AGENT_RPC_LISTEN_ADDR=unix:///tmp/agent-python-rpc.sock
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_CHAT_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
SILICONFLOW_TIMEOUT_SECONDS=30
SILICONFLOW_TEMPERATURE=0.2
LLM_PROVIDER=siliconflow
LLM_AGENT_MAX_CONTEXT_CHUNKS=6
