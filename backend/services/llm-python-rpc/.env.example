# Load order: config/defaults.json -> .env -> process env
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_CHAT_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
SILICONFLOW_TIMEOUT_SECONDS=30
SILICONFLOW_TEMPERATURE=0.2

# Optional internal auth between core-go-rpc -> llm-python-rpc
INTERNAL_SERVICE_TOKEN=

# LLM python rpc bind address
LLM_RPC_ADDR=:19091

# Optional alternate config file path
# LLM_CONFIG_FILE=config/defaults.json
