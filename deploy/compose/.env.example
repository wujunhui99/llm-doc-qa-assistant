# Required for GHCR image pull
GHCR_USERNAME=<your-github-username-or-org>
IMAGE_TAG=main

# Runtime provider (ollama | openai | siliconflow)
LLM_PROVIDER=ollama

# Optional provider configs
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OLLAMA_API_BASE=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen3.5:latest
SILICONFLOW_API_KEY=
SILICONFLOW_CHAT_MODEL=Pro/MiniMaxAI/MiniMax-M2.5
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B

# Optional database/object/vector overrides
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=llm_doc_qa
MYSQL_USER=app
MYSQL_PASSWORD=app123456
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
QDRANT_COLLECTION=qa_chunks
